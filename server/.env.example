# MongoDB
MONGODB_URI=mongodb://localhost:27017/surveymage

# Server
PORT=5000
NODE_ENV=development

# CORS - allowed origin (required in production; defaults to http://localhost:3000 in dev)
CORS_ORIGIN=http://localhost:3000

# API version prefix (default: v1)
API_VERSION=v1

# Logging (error|warn|info|debug)
LOG_LEVEL=info
