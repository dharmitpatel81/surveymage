# MongoDB - always include database name in URI
# Local: mongodb://localhost:27017/surveymage
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/surveymage?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/surveymage

# Server
PORT=5000
NODE_ENV=development

# CORS - required in production (defaults to http://localhost:3000 in dev)
CORS_ORIGIN=http://localhost:3000

# API (optional)
API_VERSION=v1
LOG_LEVEL=info

# Firebase (optional - projectId can come from serviceAccountKey.json)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_SERVICE_ACCOUNT_JSON=full JSON from serviceAccountKey.json (for Render/Railway - paste as single line)
